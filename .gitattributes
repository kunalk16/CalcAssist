# Normalize line endings: keep Go and text sources LF so gofmt/CI are stable on Windows.
* text=auto eol=lf

*.go     text eol=lf
*.mod    text eol=lf
*.sum    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
Makefile text eol=lf

# PowerShell scripts use CRLF.
*.ps1    text eol=crlf

# Treat known binaries as binary.
*.png    binary
*.jpg    binary
*.pdf    binary
*.xlsx   binary
*.docx   binary
*.exe    binary
